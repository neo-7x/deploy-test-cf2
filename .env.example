# Deploy Test — environment variables.
# Copy to .env and fill in.
#
# On one-click deploys (Vercel / Cloudflare Workers), this file is also used
# by the deploy form to discover which variables to ask the user for. Every
# uncommented KEY= line becomes a form field; leave empty string as default.

# =============================================================================
# REQUIRED
# =============================================================================

# Postgres connection string. Format: postgresql://user:pass@host:port/db
# Works with any Postgres; no extensions required for this PoC.
#
# On Cloudflare Workers: this is used at BUILD TIME to run migrations, and must
# point at the same Postgres that the POSTGRES Hyperdrive binding is wired to.
# At runtime the Worker reads through Hyperdrive, not DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deploy_test

# Session / cookie encryption secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-random-string

# =============================================================================
# ADMIN BOOTSTRAP
# =============================================================================

# Comma-separated emails. When a sign-up lands any email in this list, that
# user is promoted to role=admin on creation. No seed account and no default
# credentials — you become admin by registering with an email you control.
#
# Default is `admin@admin.local` so the PoC is usable out of the box; REPLACE
# THIS with your own email before sharing the deploy URL. Example:
#   SYSTEM_ADMIN_EMAILS=you@example.com,ops@example.com
SYSTEM_ADMIN_EMAILS=admin@admin.local

# =============================================================================
# OPTIONAL — Sign-in methods
# =============================================================================
# If no OAuth is configured, email+password login is auto-enabled so the
# install is never locked out. Leaving these empty is safe.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Force-toggle email login. Values: true | false
# Default: on iff no OAuth is configured.
AUTH_EMAIL_ENABLED=

# =============================================================================
# OPTIONAL — Transactional email (Resend)
# =============================================================================
# When RESEND_API_KEY is set, email verification auto-activates on signup.
# Without a verified custom domain, Resend only delivers to the account owner's
# email (onboarding@resend.dev sandbox). Add a domain at resend.com/domains and
# set RESEND_FROM accordingly to send to anyone.

RESEND_API_KEY=
RESEND_FROM=

# Force-toggle email verification. Values: true | false
# Default: on iff email login is enabled and RESEND_API_KEY is set.
AUTH_EMAIL_VERIFICATION=
